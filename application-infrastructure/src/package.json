		"lambda",
		"api gateway",
		"cloudformation",
		"sam",
		"api",
		"proxy",
		"remote falcon",
		"holiday light show",
		"metrics",
		"telemetry"
	],
	"main": "index.js",
	"license": "MIT",
	"engines": {
