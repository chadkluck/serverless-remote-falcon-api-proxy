{
  "name": "backend-tests",
  "version": "1.0.0",
  "description": "Backend testing configuration",
  "type": "commonjs",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:dependencies": "node ./tests/utils/dependencyAnalysis.js",
    "test:all": "npm run test:dependencies && npm run test"
  },
  "dependencies": {
    "@aws-sdk/client-lambda": "^3.962.0",
    "@aws-sdk/client-ssm": "^3.962.0",
    "jose": "^6.1.3"
  },
  "devDependencies": {
    "fast-check": "^3.15.0",
    "jest": "^29.7.0"
  },
  "jest": {
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/**/*.test.js"
    ],
    "testEnvironment": "node",
    "setupFilesAfterEnv": [
      "./tests/setup/testSetup.js"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ]
  }
}
