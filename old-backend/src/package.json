{
  "name": "remote-falcon-proxy",
  "version": "1.0.0",
  "description": "Remote Falcon JWT Proxy Lambda Function",
  "main": "index.js",
  "type": "commonjs",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "package": "zip -r function.zip . -x 'tests/*' '*.test.js' '*.spec.js' 'node_modules/.cache/*'"
  },
  "dependencies": {
    "@aws-sdk/client-ssm": "^3.0.0",
    "jose": "^5.0.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "fast-check": "^3.15.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "jest": {
    "testMatch": ["**/tests/**/*.test.js"],
    "collectCoverageFrom": [
      "*.js",
      "!*.test.js",
      "!*.spec.js"
    ],
    "testEnvironment": "node",
    "setupFilesAfterEnv": ["./tests/setup/testSetup.js"],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/tests/"
    ]
  }
}